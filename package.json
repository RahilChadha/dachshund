{
  "name": "dachshund",
  "version": "0.1.0",
  "description": "Mini medallion-architecture listings pipeline (bronze/silver/gold) for vehicle data, modeled on Cardog's Crawldog architecture.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "capture:reference": "tsx scripts/capture-reference.ts",
    "db:apply-schema": "tsx src/db/apply-schema.ts",
    "generate": "tsx src/generator/index.ts",
    "extract": "tsx src/pipeline/extract.ts",
    "pipeline": "tsx src/pipeline/run.ts",
    "replay": "tsx src/pipeline/run.ts",
    "db:apply-phase3": "tsx src/db/apply-phase3-migration.ts",
    "db:apply-phase3-post-load": "tsx src/db/apply-phase3-post-load.ts",
    "benchmark:load": "tsx scripts/benchmark-load.ts",
    "benchmark:queries": "tsx scripts/benchmark-queries.ts",
    "metrics:report": "tsx scripts/metrics-report.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/lib-storage": "^3.750.0",
    "@cardog/corgi": "^2.0.4",
    "csv-parse": "^7.0.1",
    "dotenv": "^16.4.5",
    "pg": "^8.13.1",
    "pg-copy-streams": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/pg-copy-streams": "^1.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
